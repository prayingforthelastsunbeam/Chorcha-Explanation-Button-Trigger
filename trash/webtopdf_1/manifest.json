{
   "action": {
      "default_icon": "Icons/icon64.png",
      "default_popup": "index.html"
   },
   "background": {
      "service_worker": "background/background.js"
   },
   "content_scripts": [ {
      "css": [ "css/styles.css" ],
      "js": [ "libs/jquery.min.js", "content/content.js" ],
      "matches": [ "http://*/*", "https://*/*" ]
   } ],
   "default_locale": "en",
   "description": "Install webpage to PDF converter & capture entire webpage as pdf. Or edit PDF and download with one click.  ",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "Icons/icon128.png",
      "16": "Icons/icon16.png",
      "2000": "Icons/icon2000.png",
      "32": "Icons/icon32.png",
      "64": "Icons/icon64.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_appTitle__",
   "permissions": [ "tabs", "downloads", "notifications", "storage", "gcm", "scripting" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.2",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "redo.png", "undo.png", "webpagetopdfconverter.png" ]
   } ]
}
